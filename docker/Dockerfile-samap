FROM python:3.10-slim

LABEL maintainer="2species2pipelines"
LABEL description="Python runtime for SAMap cross-species integration (includes BLAST)"

# BLAST is required by SAMap for cross-species homology search
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    ncbi-blast+ \
    && rm -rf /var/lib/apt/lists/*

# Core single-cell packages needed by run_samap_module.py.
# Versions are NOT pinned: most pinned versions from python-methods require
# Python >=3.11, but sam-algorithm requires <3.11. Let pip resolve for 3.10.
RUN pip install --no-cache-dir --default-timeout=300 --retries=10 \
    anndata \
    numpy \
    pandas \
    scanpy \
    scipy \
    scikit-learn \
    leidenalg

# SAMap and its SAM-algorithm dependency
RUN pip install --no-cache-dir --default-timeout=300 --retries=10 \
    sam-algorithm \
    samap

RUN python -c "import samap; print('samap', samap.__version__, 'OK')" && \
    blastp -version

CMD ["/bin/bash"]
