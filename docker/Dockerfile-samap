FROM python:3.10-slim

LABEL maintainer="2species2pipelines"
LABEL description="Python runtime for SAMap cross-species integration (includes BLAST)"

# BLAST is required by SAMap for cross-species homology search
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    ncbi-blast+ \
    && rm -rf /var/lib/apt/lists/*

# Core single-cell packages (aligned with Dockerfile-python)
RUN pip install --no-cache-dir --default-timeout=300 --retries=10 \
    anndata==0.10.9 \
    numpy==1.26.4 \
    pandas==2.2.3 \
    scanpy==1.10.3 \
    scib-metrics==0.5.9 \
    scipy==1.17.1 \
    scikit-learn==1.5.2 \
    leidenalg==0.10.2

# SAMap and its SAM-algorithm dependency
RUN pip install --no-cache-dir --default-timeout=300 --retries=10 \
    sam-algorithm \
    samap

RUN python -c "import samap; print('samap', samap.__version__, 'OK')" && \
    blastp -version

CMD ["/bin/bash"]
