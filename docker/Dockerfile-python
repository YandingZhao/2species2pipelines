FROM python:3.11-slim

LABEL maintainer="2species2pipelines"
LABEL description="Python runtime for BBKNN, Scanorama, scVI, and scGen integration"

RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ \
    make \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --default-timeout=300 --retries=10 \
    anndata==0.10.9 \
    bbknn==1.6.0 \
    jax==0.4.28 \
    jaxlib==0.4.28 \
    leidenalg==0.10.2 \
    numpy==1.26.4 \
    pandas==2.2.3 \
    scanorama==1.7.4 \
    scanpy==1.10.3 \
    scib-metrics==0.5.9 \
    scgen==2.1.0 \
    scvi-tools==1.1.6 \
    scipy==1.17.1 \
    scikit-learn==1.5.2

# Feature selection methods (Phase 2)
# git is needed to install hotspot from GitHub (not on PyPI)
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --default-timeout=300 --retries=10 \
    triku==2.2.0 \
    anticor-features==0.1.8

# hotspot (Yosef lab autocorrelation; not on PyPI — install from GitHub)
RUN pip install --no-cache-dir \
    "git+https://github.com/YosefLab/Hotspot.git@master#egg=hotspot"

# scgen 2.x was written against an older scvi-tools API. Two private symbols
# were removed/renamed in scvi-tools 1.x; add compatibility shims so imports resolve.
#   1. scvi._compat.Literal  → typing.Literal (dropped when Python 3.7 support ended)
#   2. scvi.module.base.LossRecorder → renamed to LossOutput in scvi-tools 1.0
RUN python -c "\
import scvi, os; \
cp = os.path.join(os.path.dirname(scvi.__file__), '_compat.py'); \
open(cp, 'w').write('from typing import Literal\n__all__ = [\"Literal\"]\n'); \
bp = os.path.join(os.path.dirname(scvi.__file__), 'module', 'base', '__init__.py'); \
open(bp, 'a').write('\ntry:\n    from ._base_module import LossOutput as LossRecorder\nexcept ImportError:\n    pass\n')" \
    && python -c "import scgen; print('scgen', scgen.__version__, 'OK')"

CMD ["/bin/bash"]
