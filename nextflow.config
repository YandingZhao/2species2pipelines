manifest {
    name            = '2species-to-pipelines'
    author          = 'local bootstrap'
    homePage        = 'https://github.com/nf-core'
    description     = 'nf-core style base pipeline scaffold for cross-species integration workflows.'
    nextflowVersion = '>=23.10.0'
    version         = '0.1.0'
}

params {
    input             = "${projectDir}/assets/samplesheet.csv"
    outdir            = "${projectDir}/results"
    harmony_container = 'local/harmony-module:dev'
    seurat4_container = 'local/harmony-module:dev'
    fastmnn_container = 'local/harmony-module:dev'
    bbknn_container   = 'local/bbknn-module:dev'
    scanorama_container = 'local/bbknn-module:dev'
}

process {
    executor = 'local'
    cpus     = 1
    memory   = '1 GB'
    time     = '1h'
    errorStrategy = 'terminate'
}

profiles {
    standard {
        includeConfig 'conf/base.config'
    }
    test {
        includeConfig 'conf/test.config'
    }
    docker {
        docker.enabled = true
        process.container = 'ubuntu:22.04'
        process {
            withName: HARMONY_INTEGRATION {
                container = params.harmony_container
            }
            withName: SEURAT4_INTEGRATION {
                container = params.seurat4_container
            }
            withName: FASTMNN_INTEGRATION {
                container = params.fastmnn_container
            }
            withName: BBKNN_INTEGRATION {
                container = params.bbknn_container
            }
            withName: SCANORAMA_INTEGRATION {
                container = params.scanorama_container
            }
            withName: SEURAT_TO_ANNDATA_PAIR {
                container = params.harmony_container
            }
            withName: ORTHOLOG_CONVERT_PAIR {
                container = params.harmony_container
            }
        }
    }
}
